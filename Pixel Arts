<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Loja de Bonecos Pixel</title>
    <style>
        body {
            font-family: Arial, sans-serif;
        }
        .produto {
            border: 1px solid #ccc;
            padding: 15px;
            margin: 10px;
            text-align: center;
            display: inline-block;
            width: 200px;
            box-sizing: border-box;
        }
        .produto img {
            width: 100px;
            height: 100px;
        }
        .botao {
            background-color: #4CAF50;
            color: white;
            border: none;
            padding: 10px;
            cursor: pointer;
        }
        #filtros {
            margin-bottom: 20px;
        }
        .admin-section {
            margin-top: 20px;
        }
        .estoque-baixo {
            background-color: #f44336;
            color: white;
            padding: 5px;
            font-weight: bold;
        }
    </style>
</head>
<body>

    <h1>Loja de Bonecos Pixel</h1>

    <!-- Filtro de Categoria e Preço -->
    <section id="filtros">
        <h2>Filtros</h2>
        <label for="categoria">Categoria:</label>
        <select id="categoria">
            <option value="">Todas</option>
            <option value="heroi">Heróis</option>
            <option value="viloes">Vilões</option>
            <option value="magicos">Mágicos</option>
        </select>

        <label for="faixaPreco">Faixa de Preço:</label>
        <select id="faixaPreco">
            <option value="">Todos</option>
            <option value="0-30">Até R$ 30,00</option>
            <option value="30-60">De R$ 30,00 a R$ 60,00</option>
            <option value="60+">Acima de R$ 60,00</option>
        </select>
        
        <button class="botao" onclick="aplicarFiltros()">Aplicar Filtros</button>
    </section>

    <!-- Lista de Produtos -->
    <main class="produtos" id="listaProdutos">
        <!-- Produtos serão inseridos aqui -->
    </main>

    <!-- Painel de Administração -->
    <section class="admin-section">
        <h2>Painel de Administração</h2>
        
        <!-- Cadastro de Produtos -->
        <h3>Cadastrar Produto</h3>
        <form id="formProduto">
            <label for="nomeProduto">Nome:</label>
            <input type="text" id="nomeProduto" required>
            <label for="precoProduto">Preço:</label>
            <input type="number" id="precoProduto" required>
            <label for="categoriaProduto">Categoria:</label>
            <select id="categoriaProduto" required>
                <option value="heroi">Heróis</option>
                <option value="viloes">Vilões</option>
                <option value="magicos">Mágicos</option>
            </select>
            <label for="estoqueProduto">Estoque:</label>
            <input type="number" id="estoqueProduto" required>
            <button type="submit" class="botao">Adicionar Produto</button>
        </form>
    </section>

    <script>
        let produtos = [];

        // Função para adicionar produto
        function adicionarProduto(nome, preco, categoria, estoque) {
            const produto = {
                nome,
                preco,
                categoria,
                estoque,
                id: Date.now()
            };
            produtos.push(produto);
            salvarProdutos();
            renderizarProdutos();
        }

        // Função para salvar produtos no localStorage
        function salvarProdutos() {
            localStorage.setItem('produtos', JSON.stringify(produtos));
        }

        // Função para carregar produtos do localStorage
        function carregarProdutos() {
            const produtosSalvos = JSON.parse(localStorage.getItem('produtos'));
            if (produtosSalvos) {
                produtos = produtosSalvos;
            }
        }

        // Função para renderizar os produtos
        function renderizarProdutos() {
            const listaProdutos = document.getElementById('listaProdutos');
            listaProdutos.innerHTML = '';

            produtos.forEach(produto => {
                const produtoDiv = document.createElement('div');
                produtoDiv.classList.add('produto');
                produtoDiv.innerHTML = `
                    <img src="https://via.placeholder.com/100" alt="${produto.nome}">
                    <h3>${produto.nome}</h3>
                    <p>R$ ${produto.preco}</p>
                    <p>Categoria: ${produto.categoria}</p>
                    <p>Estoque: ${produto.estoque}</p>
                    ${produto.estoque <= 3 ? '<p class="estoque-baixo">Estoque baixo!</p>' : ''}
                    <button class="botao" onclick="comprarProduto(${produto.id})">Comprar</button>
                    <button class="botao" onclick="editarProduto(${produto.id})">Editar</button>
                    <button class="botao" onclick="removerProduto(${produto.id})">Remover</button>
                `;
                listaProdutos.appendChild(produtoDiv);
            });
        }

        // Função para aplicar filtros
        function aplicarFiltros() {
            const categoria = document.getElementById('categoria').value;
            const faixaPreco = document.getElementById('faixaPreco').value;

            const listaProdutos = document.querySelectorAll('.produto');
            listaProdutos.forEach(produto => {
                const produtoCategoria = produto.querySelector('p:nth-child(3)').textContent.split(': ')[1];
                const produtoPreco = parseFloat(produto.querySelector('p:nth-child(2)').textContent.replace('R$ ', '').replace(',', '.'));

                let categoriaOk = categoria === '' || produtoCategoria === categoria;
                let precoOk = false;
                if (faixaPreco === '0-30' && produtoPreco <= 30) precoOk = true;
                if (faixaPreco === '30-60' && produtoPreco > 30 && produtoPreco <= 60) precoOk = true;
                if (faixaPreco === '60+' && produtoPreco > 60) precoOk = true;

                if (categoriaOk && precoOk) {
                    produto.style.display = 'block';
                } else {
                    produto.style.display = 'none';
                }
            });
        }

        // Função para comprar produto
        function comprarProduto(id) {
            alert('Produto comprado!');
        }

        // Função para editar produto
        function editarProduto(id) {
            const produto = produtos.find(p => p.id === id);
            if (produto) {
                document.getElementById('nomeProduto').value = produto.nome;
                document.getElementById('precoProduto').value = produto.preco;
                document.getElementById('categoriaProduto').value = produto.categoria;
                document.getElementById('estoqueProduto').value = produto.estoque;
                removerProduto(id);
            }
        }

        // Função para remover produto
        function removerProduto(id) {
            produtos = produtos.filter(p => p.id !== id);
            salvarProdutos();
            renderizarProdutos();
        }

        // Adiciona produto ao carregar a página
        document.getElementById('formProduto').addEventListener('submit', function (e) {
            e.preventDefault();
            const nome = document.getElementById('nomeProduto').value;
            const preco = parseFloat(document.getElementById('precoProduto').value);
            const categoria = document.getElementById('categoriaProduto').value;
            const estoque = parseInt(document.getElementById('estoqueProduto').value);

            adicionarProduto(nome, preco, categoria, estoque);
            this.reset();
        });

        // Carregar produtos ao carregar a página
        carregarProdutos();
        renderizarProdutos();
    </script>

</body>
</html>
